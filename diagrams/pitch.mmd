%% =========================================================================
%% 1. VALUE PROP — what does a paralegal get?
%% =========================================================================
flowchart LR
    %% --- left column: what they ask ---
    P([👤 Paralegal on WhatsApp])
    Q1["Statute lookup<br/>“What's CVC § 23152(a)?”"]
    Q2["Fact pattern<br/>“Rear-ender, San Francisco,<br/>$100K policy limits”"]
    Q3["Case-law search<br/>“How have courts interpreted<br/>Tex. Transp. Code § 545.351?”"]

    P --> Q1
    P --> Q2
    P --> Q3

    %% --- center: Specter ---
    S(((🥃 Specter<br/><br/>Harvey-voiced<br/>WhatsApp agent)))
    Q1 --> S
    Q2 --> S
    Q3 --> S

    %% --- right column: what they get back ---
    R1["📋 PI brief<br/>• Bluebook citation<br/>• Pull quote, paste-ready<br/>• NPS analysis<br/>• Common defenses<br/>• Evidence checklist<br/>• ✅ Source URL on every cite"]
    R2["📁 Case workup<br/>• Applicable statutes<br/>• Damages comparables<br/>• Coverage gaps flagged<br/>• ✅ Sourced or refused"]
    R3["⚖️ Appellate cases<br/>• Real opinion names<br/>• Court + year<br/>• CourtListener URLs<br/>• ✅ No paraphrasing"]

    S --> R1
    S --> R2
    S --> R3

    %% --- the discipline that makes it different ---
    DISC{{"🚫 No fabrication<br/>Every § ships with a URL,<br/>or it doesn't appear."}}
    R1 --- DISC
    R2 --- DISC
    R3 --- DISC

    classDef question fill:#fef3c7,stroke:#d97706,color:#000
    classDef agent     fill:#1e3a8a,stroke:#1e40af,color:#fff,stroke-width:3px
    classDef result    fill:#dcfce7,stroke:#16a34a,color:#000
    classDef rule      fill:#fee2e2,stroke:#dc2626,color:#000

    class Q1,Q2,Q3 question
    class S agent
    class R1,R2,R3 result
    class DISC rule


%% =========================================================================
%% 2. ARCHITECTURE — how the no-fabrication discipline is enforced
%% =========================================================================
flowchart TB
    User([👤 Paralegal])
    WA[WhatsApp]
    User <--> WA

    WA <--> OC[OpenClaw agent<br/><b>Specter persona + 6 skills</b>]

    %% --- skills layer ---
    subgraph SKILLS [Skills]
        direction LR
        SK1[harvester_query<br/>statute lookup]
        SK2[caselaw_query<br/>CourtListener]
        SK3[pi_brief_format<br/>Harvey-voiced brief]
        SK4[citation_format<br/>normalize messy cites]
        SK5[web_fallback<br/>verified live fetch]
        SK6[canada_memo<br/>CanLII case memo]
    end
    OC --> SKILLS

    %% --- API + data layer ---
    SKILLS --> API[FastAPI · :8000<br/>10+ endpoints]

    API --> CHRO[(Chroma · split collections)]
    CHRO --> US[(US · 384 statutes<br/>CA · TX · FL · PA · IL · OH)]
    CHRO --> CA[(Canada · 340 PI cases<br/>real CanLII corpus)]

    API --> CL[(CourtListener API<br/>US appellate opinions)]
    API --> WIKI[(wiki/<br/>22 authoritative sources<br/>· legislatures<br/>· bar associations<br/>· court systems)]
    API --> LIVE[(.gov live verify<br/>leginfo · flsenate · etc.)]

    %% --- enrichment ---
    EMB[Voyage law-2<br/>1024-dim legal embeddings<br/>+ RPM-throttled cache]
    LLM[Claude Haiku<br/>factor + topic enrichment<br/>+ gap detection]
    CHRO --- EMB
    API --- LLM

    %% --- the discipline gate ---
    GATE{{"🛡️ verify-or-refuse gate<br/>anchor check · structural check ·<br/>SOUL forbidden-words list ·<br/>'every § ships with a URL'"}}
    SKILLS -.-> GATE
    GATE -.-> OC

    classDef chan      fill:#1e3a8a,stroke:#1e40af,color:#fff
    classDef agent     fill:#7c3aed,stroke:#6d28d9,color:#fff
    classDef skill     fill:#fef3c7,stroke:#d97706,color:#000
    classDef api       fill:#ddd6fe,stroke:#7c3aed,color:#000
    classDef store     fill:#dcfce7,stroke:#16a34a,color:#000
    classDef external  fill:#bae6fd,stroke:#0284c7,color:#000
    classDef gate      fill:#fee2e2,stroke:#dc2626,color:#000,stroke-width:3px

    class WA chan
    class OC agent
    class SK1,SK2,SK3,SK4,SK5,SK6 skill
    class API api
    class CHRO,US,CA,WIKI store
    class CL,LIVE,EMB,LLM external
    class GATE gate


