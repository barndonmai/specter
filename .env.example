# Copy to .env and fill in
ANTHROPIC_API_KEY=sk-ant-...
VOYAGE_API_KEY=pa-...

# Chroma — local persistent
CHROMA_PERSIST_DIR=./.chroma
CHROMA_COLLECTION=specter_statutes

# API
API_HOST=0.0.0.0
API_PORT=8000

# Models
VOYAGE_MODEL=voyage-law-2
ANTHROPIC_MODEL=claude-haiku-4-5

# Voyage rate limit. Free tier = 3 RPM. Paid (after adding card) = 300+ RPM.
# The embed layer enforces this on every call site, so we never get 429s.
VOYAGE_RPM=3
# In-memory cache for repeated queries (keyed by text+input_type+model).
VOYAGE_CACHE_SIZE=4096
